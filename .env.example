# Camera (Windows: if MSMF fails, set CAMERA_BACKEND=DSHOW)
CAMERA_INDEX=0
CAMERA_BACKEND=auto
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=10
# Faster CPU: INFERENCE_WIDTH=320 INFERENCE_HEIGHT=240 PROCESS_EVERY_N_FRAMES=2
INFERENCE_WIDTH=0
INFERENCE_HEIGHT=0
PROCESS_EVERY_N_FRAMES=1

# Segmentation backend: ADE20K SegFormer (indoor + outdoor scenes)
SEGMENTER_BACKEND=segformer
SEGFORMER_MODEL_ID=nvidia/segformer-b2-finetuned-ade-512-512
SEGFORMER_DEVICE=auto
# Inference image size (0 = model default; lower for faster CPU inference)
INFERENCE_IMGSZ=0

# UniDepthV2 (set path when weights are downloaded)
UNIDEPTH_MODEL_PATH=
UNIDEPTH_DEVICE=auto

# CARE safety / navigation (HTTP or local — adapt care.py)
CARE_ENDPOINT=http://127.0.0.1:8000/predict
CARE_TIMEOUT_SEC=2.0
USE_CARE_HTTP=false

# Llama 3.1 via OpenAI-compatible API (Ollama, vLLM, Groq, etc.)
# Set USE_LLM=true after: ollama pull llama3.1  (or match OPENAI_MODEL to `ollama list`)
USE_LLM=false
OPENAI_API_KEY=
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_MODEL=llama3.1

# Safety validator
COMMAND_COOLDOWN_SEC=2.0
REPEAT_COMMAND_SUPPRESS=true

# TTS (pyttsx3 uses system voices)
TTS_ENABLED=true
TTS_RATE=175
HAZARD_OBSTACLE_RATIO=0.03

# Map-assisted navigation
USE_MAP_GUIDANCE=false
# Route provider: osrm (free) or google (Directions API — walking routes only).
ROUTE_PROVIDER=osrm
# Required when ROUTE_PROVIDER=google. Set in Render dashboard, not in git.
GOOGLE_MAPS_API_KEY=
# Start position (laptop demo — no GPS; set fixed coords near your route)
CURRENT_LAT=
CURRENT_LON=
CURRENT_HEADING_DEG=0
# Destination
DEST_LAT=
DEST_LON=
ROUTE_AT_DEST_M=15
ROUTE_OFF_ROUTE_M=30
ROUTE_BEARING_ALIGN_DEG=25
ROUTE_DEBUG_PATH=output/route.json
